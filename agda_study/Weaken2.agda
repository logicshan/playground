  вҲ…    :  Con
  _в–·_  :  Con вҶ’ Type вҶ’ Con

variable
    О“ О” Оҳ Оһ : Con

_ : Con
_ = вҲ… в–· (`в„• вҮ’ `в„•) в–· `в„•

data _вҠў_ : Con вҶ’ Type вҶ’ Set where

  в—Ҹ :
      -----------
       О“ в–· A вҠў A

  _вҶ‘ :
      (M : О“ вҠў B)
    вҶ’ -----------
       О“ в–· A вҠў B

  Жӣ_ :
      (N : О“ в–· A вҠў B)
    вҶ’ ---------------
       О“ вҠў A вҮ’ B

  _В·_ :
      (L : О“ вҠў A вҮ’ B)
      (M : О“ вҠў A)
    вҶ’ ---------------
       О“ вҠў B

  zero :
       --------
        О“ вҠў `в„•

  suc :
      (M : О“ вҠў `в„•)
    вҶ’ -------------
       О“ вҠў `в„•

variable
  L M N P Q : О“ вҠў A

inc : вҲ… вҠў `в„• вҮ’ `в„•
inc = Жӣ (suc в—Ҹ)

two : вҲ… вҠў (A вҮ’ A) вҮ’ A вҮ’ A
two = Жӣ (Жӣ (в—Ҹ вҶ‘ В· (в—Ҹ вҶ‘ В· в—Ҹ)))

MвӮҖ MвӮҒ : вҲ… в–· (A вҮ’ B вҮ’ C) в–· A в–· B вҠў C
MвӮҖ = в—Ҹ вҶ‘ вҶ‘ В· в—Ҹ вҶ‘ В· в—Ҹ
MвӮҒ = (в—Ҹ вҶ‘  В· в—Ҹ) вҶ‘ В· в—Ҹ 

data _вҠЁ_ : Con вҶ’ Con вҶ’ Set where

  id :
      -------
       О” вҠЁ О”

  _вҶ‘ :
      (Пғ : О“ вҠЁ О”)
    вҶ’ -----------
       О“ в–· A вҠЁ О”

  _в–·_ :
      (Пғ : О“ вҠЁ О”)
      (M : О“ вҠў A)
    вҶ’ -----------
       О“ вҠЁ О” в–· A

variable
  Пғ П„ П… : О“ вҠЁ О”

_ : вҲ… вҠЁ вҲ… в–· (`в„• вҮ’ `в„•) в–· `в„•
_ = id в–· inc в–· zero

_ : вҲ… в–· `в„• вҠЁ вҲ… в–· `в„• вҮ’ `в„• в–· `в„•
_ = (id в–· inc) вҶ‘ в–· в—Ҹ

_ : вҲ… в–· A в–· B вҠЁ вҲ… в–· B в–· A
_ = id вҶ‘ вҶ‘ в–· в—Ҹ в–· в—Ҹ вҶ‘

pattern в–і  =  _ в–· _

_[_] :
    (M : О” вҠў A)
    (Пғ : О“ вҠЁ О”)
  вҶ’ -----------
     О“ вҠў A
M             [ id ]     =  M                  -- (1)
M             [ Пғ вҶ‘ ]    =  (M [ Пғ ]) вҶ‘        -- (2)
в—Ҹ             [ Пғ в–· P ]  =  P                  -- (3)
(M вҶ‘)         [ Пғ в–· P ]  =  M [ Пғ ]            -- (4)
(Жӣ N)         [ Пғ @ в–і ]  =  Жӣ (N [ Пғ вҶ‘ в–· в—Ҹ ])  -- (5)
(L В· M)       [ Пғ @ в–і ]  =  L [ Пғ ] В· M [ Пғ ]  -- (6)
zero          [ Пғ @ в–і ]  =  zero               -- (7)
(suc M)       [ Пғ @ в–і ]  =  suc (M [ Пғ ])      -- (8)

_ : (Жӣ (в—Ҹ вҶ‘ В· (в—Ҹ вҶ‘ В· в—Ҹ))) [ id в–· inc ]  вүЎ  Жӣ (inc вҶ‘ В· (inc вҶ‘ В· в—Ҹ))
_ =
    begin
      (Жӣ (в—Ҹ вҶ‘ В· (в—Ҹ вҶ‘ В· в—Ҹ))) [ id в–· inc ]
    вүЎвҹЁвҹ©         -- (5)
      Жӣ ((в—Ҹ вҶ‘ В· (в—Ҹ вҶ‘ В· в—Ҹ)) [ (id в–· inc) вҶ‘ в–· в—Ҹ ])
    вүЎвҹЁвҹ©         -- (6)
      Жӣ (((в—Ҹ вҶ‘) [ (id в–· inc) вҶ‘ в–· в—Ҹ ]) В· ((в—Ҹ вҶ‘ В· в—Ҹ) [ (id в–· inc) вҶ‘ в–· в—Ҹ ]))
    вүЎвҹЁвҹ©         -- (4)
      Жӣ ((в—Ҹ [ (id в–· inc) вҶ‘ ]) В· ((в—Ҹ вҶ‘ В· в—Ҹ) [ (id в–· inc) вҶ‘ в–· в—Ҹ ]))
    вүЎвҹЁвҹ©         -- (2)
      Жӣ ((в—Ҹ [ id в–· inc ]) вҶ‘ В· ((в—Ҹ вҶ‘ В· в—Ҹ) [ (id в–· inc) вҶ‘ в–· в—Ҹ ]))
    вүЎвҹЁвҹ©         -- (3)
      Жӣ (inc вҶ‘ В· ((в—Ҹ вҶ‘ В· в—Ҹ) [ (id в–· inc) вҶ‘ в–· в—Ҹ ]))
    вүЎвҹЁвҹ©         --  ...
      Жӣ (inc вҶ‘ В· (inc вҶ‘ В· в—Ҹ))
    вҲҺ

_ : (Жӣ (в—Ҹ вҶ‘ В· (в—Ҹ вҶ‘ В· в—Ҹ))) [ id в–· inc ]  вүЎ  Жӣ (inc вҶ‘ В· (inc вҶ‘ В· в—Ҹ))
_ = refl

_вЁҫ_ :
    (Пғ : Оҳ вҠЁ О”)
    (П„ : О“ вҠЁ Оҳ)
  вҶ’ -----------
     О“ вҠЁ О”
Пғ        вЁҫ  id       =  Пғ                    -- (1)
Пғ        вЁҫ  (П„ вҶ‘)    =  (Пғ вЁҫ П„) вҶ‘            -- (2)
id       вЁҫ  (П„ @ в–і)  =  П„                    -- (3)
(Пғ вҶ‘)    вЁҫ  (П„ в–· Q)  =  Пғ вЁҫ П„                -- (4)
(Пғ в–· P)  вЁҫ  (П„ @ в–і)  =  (Пғ вЁҫ П„) в–· (P [ П„ ])  -- (5)

[][] :
    (M : О” вҠў A)
    (Пғ : Оҳ вҠЁ О”)
    (П„ : О“ вҠЁ Оҳ)
  вҶ’ -----------------------------
     M [ Пғ ] [ П„ ] вүЎ M [ Пғ вЁҫ П„ ]

[][]  M             Пғ        id       =  refl                                  --  (1)
[][]  M             Пғ        (П„ вҶ‘)    =  cong _вҶ‘ ([][] M Пғ П„)                  --  (2)
[][]  M             id       (П„ @ в–і)  =  refl                                  --  (3)
[][]  M             (Пғ вҶ‘)    (П„ в–· Q)  =  [][] M Пғ П„                            --  (4)
[][]  в—Ҹ             (Пғ в–· P)  (П„ @ в–і)  =  refl                                  --  (5)
[][]  (M вҶ‘)         (Пғ в–· P)  (П„ @ в–і)  =  [][] M Пғ П„                            --  (6)
[][]  (Жӣ N)         (Пғ @ в–і)  (П„ @ в–і)  =  cong Жӣ_ ([][] N (Пғ вҶ‘ в–· в—Ҹ) (П„ вҶ‘ в–· в—Ҹ))  --  (7)
[][]  (L В· M)       (Пғ @ в–і)  (П„ @ в–і)  =  congвӮӮ _В·_ ([][] L Пғ П„) ([][] M Пғ П„)   --  (8)
[][]  zero          (Пғ @ в–і)  (П„ @ в–і)  =  refl                                  --  (9)
[][]  (suc M)       (Пғ @ в–і)  (П„ @ в–і)  =  cong suc ([][] M Пғ П„)                 -- (10)

{-# REWRITE [][] #-}

left-id :
    (П„ : О“ вҠЁ О”)
  вҶ’ ------------
     id вЁҫ П„ вүЎ П„
left-id id       =  refl                 -- (1)
left-id (П„ вҶ‘)    =  cong _вҶ‘ (left-id П„)  -- (2)
left-id (П„ в–· Q)  =  refl                 -- (3)

{-# REWRITE left-id #-}

assoc :
    (Пғ : Оҳ вҠЁ О”)
    (П„ : Оһ вҠЁ Оҳ)
    (П… : О“ вҠЁ Оһ)
  вҶ’ ---------------------------
     (Пғ вЁҫ П„) вЁҫ П… вүЎ Пғ вЁҫ (П„ вЁҫ П…)
assoc  Пғ        П„        id       =  refl                                      -- (1)
assoc  Пғ        П„        (П… вҶ‘)    =  cong _вҶ‘ (assoc Пғ П„ П…)                     -- (2)
assoc  Пғ        id       (П… в–· R)  =  refl                                      -- (3)
assoc  Пғ        (П„ вҶ‘)    (П… в–· R)  =  assoc Пғ П„ П…                               -- (4)
assoc  id       (П„ в–· Q)  (П… в–· R)  =  refl                                      -- (5)
assoc  (Пғ вҶ‘)    (П„ в–· Q)  (П… в–· R)  =  assoc Пғ П„ (П… в–· R)                         -- (6)
assoc  (Пғ в–· P)  (П„ в–· Q)  (П… в–· R)  =  congвӮӮ _в–·_ (assoc Пғ (П„ в–· Q) (П… в–· R)) refl  -- (7)

{-# REWRITE assoc #-}

